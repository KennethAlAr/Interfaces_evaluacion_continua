<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="800.0" stylesheets="@../style/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.InicioController">
   <children>
      <HBox layoutX="271.0" layoutY="25.0">
         <children>
            <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../assets/icono_appuntalo.png" />
               </image>
            </ImageView>
            <Label alignment="CENTER" contentDisplay="TOP" prefHeight="30.0" styleClass="titulo-app" text="APPUNTALO"/>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="100.0" prefHeight="20.0" spacing="15.0">
         <children>
            <Label prefWidth="200.0" styleClass="cabecera-columna" text="NOMBRE"/>
            <Label prefWidth="288.0" styleClass="cabecera-columna" text="DESCRIPCIÓN"/>
            <Label prefWidth="75.0" styleClass="cabecera-columna" text="ELEMENTOS"/>
         </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <VBox fx:id="vboxPrincipal" layoutX="20.0" layoutY="130.0" prefHeight="600.0" prefWidth="760.0" spacing="10.0">
         <children>
            <ListView fx:id="listViewListas" prefHeight="540.0" prefWidth="760.0" styleClass="lista-transparente" />
         </children>
      </VBox>
      <Button layoutX="20.0" layoutY="750.0" mnemonicParsing="false" onAction="#btnNuevaLista" prefHeight="30.0" prefWidth="90.0" styleClass="boton-primario" text="Nueva Lista" />
      <Button layoutX="720.0" layoutY="750.0" mnemonicParsing="false" onAction="#btnSalir" prefHeight="30.0" prefWidth="60.0" styleClass="boton-secundario" text="Salir" />
      <Button layoutX="615.0" layoutY="750.0" mnemonicParsing="false" onAction="#btnBorrarTodo" prefHeight="30.0" prefWidth="95.0" styleClass="boton-peligro" text="Borrar Todo" />
   </children>
</AnchorPane>
