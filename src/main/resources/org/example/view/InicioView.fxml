<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.InicioController">
   <children>
      <Label alignment="CENTER" contentDisplay="TOP" layoutX="166.0" layoutY="14.0" prefHeight="57.0" prefWidth="269.0" text="APPUNTALO" textAlignment="CENTER">
         <font>
            <Font name="Carlito Bold" size="40.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="70.0" prefWidth="530.0" spacing="15.0">
         <children>
            <Label prefWidth="150.0" text="NOMBRE" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label prefWidth="200.0" text="DESCRIPCIÓN" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label prefWidth="100.0" text="ELEMENTOS" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <ScrollPane fx:id="scrollTableroListas" fitToWidth="true" layoutX="35.0" layoutY="95.0" prefHeight="225.0" prefWidth="530.0">
         <content>
            <VBox fx:id="vboxListas" spacing="10.0" />
         </content>
      </ScrollPane>
      <Button layoutX="35.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnNuevaLista" text="Nueva Lista" />
      <Button layoutX="521.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnSalir" text="Salir" />
      <Button layoutX="417.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnBorrarTodo" text="Borrar Todo" />
   </children>
</AnchorPane>
