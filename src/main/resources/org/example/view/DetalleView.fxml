<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.DetalleController">
   <children>
      <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="70.0" prefWidth="530.0" spacing="15.0">
         <children>
            <Label prefWidth="150.0" text="NOMBRE" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label prefWidth="100.0" text="CANTIDAD" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label prefWidth="200.0" text="DESCRIPCIÓN" textFill="#555555">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <ScrollPane fx:id="scrollTableroElementos" fitToWidth="true" layoutX="35.0" layoutY="95.0" prefHeight="225.0" prefWidth="530.0">
         <content>
            <VBox fx:id="vboxElementos" spacing="10.0" />
         </content>
      </ScrollPane>
      <Button layoutX="35.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnNuevoElemento" text="Nuevo Elemento" />
      <Button layoutX="507.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnVolver" text="Volver" />
      <Button layoutX="399.0" layoutY="332.0" mnemonicParsing="false" onAction="#btnBorrarTodosElementos" text="Borrar Todo" />
      <Label fx:id="txtNombreLista" contentDisplay="TOP" layoutX="45.0" layoutY="4.0" prefHeight="34.0" prefWidth="475.0" text="Nombre de la Lista" textAlignment="CENTER">
         <font>
            <Font name="Carlito Bold" size="28.0" />
         </font>
      </Label>
      <Label fx:id="txtDescripcionLista" alignment="TOP_LEFT" contentDisplay="TOP" layoutX="45.0" layoutY="33.0" prefHeight="34.0" prefWidth="475.0" text="Descripción de la lista" textAlignment="CENTER">
         <font>
            <Font name="Carlito" size="16.0" />
         </font>
      </Label>
      <Button fx:id="btnEditarLista" layoutX="531.0" layoutY="20.0" mnemonicParsing="false" onAction="#accionEditarLista" text="EL" />
   </children>
</AnchorPane>
