<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" onMouseClicked="#btnElegirLista" prefHeight="55.0" spacing="15.0" styleClass="fila-pildora" stylesheets="@../style/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FilaListaController">
   <children>
      <Label fx:id="lblNombre" prefWidth="200.0" text="Nombre de la Lista" />
      <Label fx:id="lblDescripcion" prefWidth="300.0" text="Descripción breve" />
      <Label fx:id="lblCantidad" alignment="CENTER" prefWidth="50.0" text="0 elementos" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="btnBorrar" mnemonicParsing="false" onAction="#accionBorrar" styleClass="boton-icono">
         <graphic>
            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../assets/papelera-de-reciclaje.png" />
               </image>
            </ImageView>
         </graphic></Button>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
