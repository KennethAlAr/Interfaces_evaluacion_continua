<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" onMouseClicked="#btnElegirLista" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FilaListaController">
   <children>
      <Label fx:id="lblNombre" prefWidth="150.0" text="Nombre de la Lista" />
      <Label fx:id="lblDescripcion" prefWidth="200.0" text="Descripción breve" />
      <Label fx:id="lblCantidad" prefWidth="100.0" text="0 elementos" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="btnBorrar" mnemonicParsing="false" onAction="#accionBorrar" text="X" />
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
