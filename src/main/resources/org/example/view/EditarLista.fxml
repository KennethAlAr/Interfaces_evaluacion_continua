<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.EditarListaController">
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Editar Lista" />

        <TextField fx:id="txtEditarNombreLista" promptText="Nombre de la lista..." />
        <TextField fx:id="txtEditarDescripcionLista" promptText="Descripción breve..." />

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#accionCancelar" text="Cancelar" />
                <Button mnemonicParsing="false" onAction="#accionGuardarEdicion" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
