<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="400.0" spacing="15.0" stylesheets="@../style/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.NuevaListaController">
    <children>
        <Label styleClass="titulo-ventana" text="Crear Nueva Lista" />
      <Label prefHeight="25.0" prefWidth="360.0" styleClass="etiqueta-formulario" text="Nombre de la Lista"/>

        <TextField fx:id="txtNuevoNombreLista" promptText="Nombre de la lista..." />
      <Label prefHeight="25.0" prefWidth="360.0" styleClass="etiqueta-formulario" text="Descripción de la Lista"/>
        <TextField fx:id="txtNuevaDescripcionLista" promptText="Descripción breve..." />

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#accionCancelar" styleClass="boton-secundario" text="Cancelar" />
                <Button mnemonicParsing="false" onAction="#accionGuardarLista" styleClass="boton-primario" text="Guardar" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
