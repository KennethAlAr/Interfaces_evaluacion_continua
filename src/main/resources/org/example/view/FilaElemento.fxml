<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox fx:id="hboxPrincipal" alignment="CENTER_LEFT" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FilaElementoController">
   <children>
      <Label fx:id="lblNombreElemento" prefWidth="150.0" text="Nombre del Elemento" />
      <Label fx:id="lblCantidadElemento" prefWidth="100.0" text="Cantidad de Elementos" />
      <Label fx:id="lblDescripcionElemento" prefWidth="200.0" text="Descripción del Elemento" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="btnEditarElemento" mnemonicParsing="false" onAction="#accionEditarElemento" text="E" />
      <Button fx:id="btnMarcarComprado" mnemonicParsing="false" onAction="#accionMarcarComprado" text="C" />
      <Button fx:id="btnBorrarElemento" mnemonicParsing="false" onAction="#accionBorrarElemento" text="X" />
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
