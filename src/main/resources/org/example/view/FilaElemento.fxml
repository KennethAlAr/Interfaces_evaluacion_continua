<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox fx:id="hboxPrincipal" alignment="CENTER_LEFT" prefHeight="55.0" spacing="15.0" styleClass="fila-pildora" stylesheets="@../style/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FilaElementoController">
   <children>
      <Label fx:id="lblNombreElemento" prefWidth="200.0" text="Nombre del Elemento" />
      <Label fx:id="lblCantidadElemento" alignment="CENTER" prefWidth="50.0" text="Cantidad de Elementos" />
      <Label fx:id="lblDescripcionElemento" prefWidth="300.0" text="Descripción del Elemento" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="btnMarcarComprado" mnemonicParsing="false" onAction="#accionMarcarComprado" styleClass="boton-icono">
         <graphic>
            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../assets/carrito-de-compras.png" />
               </image>
            </ImageView>
         </graphic></Button>
      <Region prefWidth="10.0" />
      <Button fx:id="btnEditarElemento" mnemonicParsing="false" onAction="#accionEditarElemento" styleClass="boton-icono">
         <graphic>
            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../assets/boton-editar.png" />
               </image>
            </ImageView>
         </graphic></Button>
      <Button fx:id="btnBorrarElemento" mnemonicParsing="false" onAction="#accionBorrarElemento" styleClass="boton-icono">
         <graphic>
            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../assets/papelera-de-reciclaje.png" />
               </image>
            </ImageView>
         </graphic></Button>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</HBox>
